--------------------------------------------------------------------
-- INTERACTION MANAGEMENT
--------------------------------------------------------------------
local function UpdateUI()
    if AimEnabled then
        AimButton.Text = "AIM LOCK: ON"
        AimButton.BackgroundColor3 = Color3.fromRGB(35, 140, 75)
        AimButton.TextColor3 = Color3.fromRGB(255, 255, 255)
        AimButton.UIStroke.Color = Color3.fromRGB(46, 204, 113)
    else
        AimButton.Text = "AIM LOCK: OFF"
        AimButton.BackgroundColor3 = Color3.fromRGB(130, 35, 35)
        AimButton.TextColor3 = Color3.fromRGB(220, 220, 220)
        AimButton.UIStroke.Color = Color3.fromRGB(231, 76, 60)
    end

    if EspEnabled then
        EspButton.Text = "ESP: ON"
        EspButton.BackgroundColor3 = Color3.fromRGB(35, 140, 75)
        EspButton.TextColor3 = Color3.fromRGB(255, 255, 255)
        EspButton.UIStroke.Color = Color3.fromRGB(46, 204, 113)
    else
        EspButton.Text = "ESP: OFF"
        EspButton.BackgroundColor3 = Color3.fromRGB(130, 35, 35)
        EspButton.TextColor3 = Color3.fromRGB(220, 220, 220)
        EspButton.UIStroke.Color = Color3.fromRGB(231, 76, 60)
        for _, v in pairs(Players:GetPlayers()) do UnloadCharacter(v) end
    end
end

-- Function maps
local function ToggleAim()
    AimEnabled = not AimEnabled
    UpdateUI()
end

local function ToggleEsp()
    EspEnabled = not EspEnabled
    UpdateUI()
    if EspEnabled then 
        for _, v in pairs(Players:GetPlayers()) do pcall(LoadCharacter, v) end 
    end
end

-- Mouse Triggers
AimButton.MouseButton1Click:Connect(ToggleAim)
EspButton.MouseButton1Click:Connect(ToggleEsp)

-- Keyboard Key Triggers
UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode == AIM_TOGGLE_KEY then
        ToggleAim()
    elseif input.KeyCode == ESP_TOGGLE_KEY then
        ToggleEsp()
    end
end)

-- Initialize listeners
for _, v in pairs(Players:GetPlayers()) do LoadPlayer(v) end
Players.PlayerAdded:Connect(LoadPlayer)
Players.PlayerRemoving:Connect(UnloadPlayer)
LocalPlayer.NameDisplayDistance = 0

UpdateUI()
