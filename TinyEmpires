        local myDisplayName = Player.DisplayName
        local plots = Workspace:FindFirstChild("Plots")
        if plots then
            local myPlot = nil
            for _, plot in pairs(plots:GetChildren()) do
                local nameLabel = plot:FindFirstChild("EmpireName", true) or plot:FindFirstChild("PlotOwnerLabel", true)
                if nameLabel and string.find(nameLabel.Text, myDisplayName) then
                    myPlot = plot
                    break
                end
            end

            if myPlot and myPlot:FindFirstChild("Buildings") then
                for _, building in pairs(myPlot.Buildings:GetChildren()) do
                    if not UIState.Active then break end
                    local prompt = building:FindFirstChild("CollectPrompt", true)
                    if prompt and prompt:IsA("ProximityPrompt") then
                        local amount = tonumber(string.match(prompt.ObjectText, "%d+")) or 0
                        if amount >= 8 then
                            local root = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
                            local targetPart = prompt.Parent or building:FindFirstChild("Floor") or building.PrimaryPart
