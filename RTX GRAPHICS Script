-- [[ 3. UI CONTROLS LOGIC ]] --
local function createSlider(name, min, max, default, callback)
	local container = Instance.new("Frame", ScrollFrame)
	container.Size = UDim2.new(0, 320, 0, 45); container.BackgroundTransparency = 1
	
	local lbl = Instance.new("TextLabel", container)
	lbl.Size = UDim2.new(1, 0, 0, 15); lbl.BackgroundTransparency = 1
	lbl.Text = name .. ": " .. tostring(default); lbl.TextColor3 = Color3.new(1,1,1)
	lbl.Font = Enum.Font.Gotham; lbl.TextSize = 12; lbl.TextXAlignment = Enum.TextXAlignment.Left
	
	local bg = Instance.new("TextButton", container)
	bg.Size = UDim2.new(1, 0, 0, 15); bg.Position = UDim2.new(0, 0, 0, 20)
	bg.BackgroundColor3 = Color3.fromRGB(40, 40, 45); bg.Text = ""; bg.AutoButtonColor = false
	Instance.new("UICorner", bg).CornerRadius = UDim.new(0, 5)
	
	local fill = Instance.new("Frame", bg)
	fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
	fill.BackgroundColor3 = Color3.fromRGB(60, 120, 220); fill.BorderSizePixel = 0
	Instance.new("UICorner", fill).CornerRadius = UDim.new(0, 5)
	
	local function updateSlider(input)
		local percent = math.clamp((input.Position.X - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
		fill.Size = UDim2.new(percent, 0, 1, 0)
		local val = min + (max - min) * percent
		val = math.floor(val * 100) / 100 
		lbl.Text = name .. ": " .. tostring(val)
		callback(val)
	end
	
	local sliding = false
	bg.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then sliding = true; updateSlider(input) end
	end)
	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then sliding = false end
	end)
	UserInputService.InputChanged:Connect(function(input)
		if sliding and input.UserInputType == Enum.UserInputType.MouseMovement then updateSlider(input) end
	end)
	
	callback(default)
	return function(val) 
		local percent = math.clamp((val - min) / (max - min), 0, 1)
		fill.Size = UDim2.new(percent, 0, 1, 0)
		lbl.Text = name .. ": " .. tostring(math.floor(val * 100) / 100)
		callback(val)
	end
end

local function createToggle(text, callback)
	local btn = Instance.new("TextButton", ScrollFrame)
	btn.Size = UDim2.new(0, 320, 0, 35)
	btn.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
	btn.Text = text .. ": OFF"
	btn.TextColor3 = Color3.new(1,1,1)
	btn.Font = Enum.Font.GothamSemibold; btn.TextSize = 13
	Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 5)
	
	local state = false
	btn.MouseButton1Click:Connect(function()
		state = not state
		btn.Text = text .. ": " .. (state and "ON" or "OFF")
		btn.BackgroundColor3 = state and Color3.fromRGB(50, 150, 50) or Color3.fromRGB(45, 45, 50)
		callback(state)
	end)
	return function(forceState)
		state = forceState
		btn.Text = text .. ": " .. (state and "ON" or "OFF")
		btn.BackgroundColor3 = state and Color3.fromRGB(50, 150, 50) or Color3.fromRGB(45, 45, 50)
		callback(state)
	end
end

