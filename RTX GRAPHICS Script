local isGlossy = false
local toggleGlossy = createToggle("🌧️ Wet / Glossy World", function(state)
	isGlossy = state
	if state then
		for _, part in ipairs(workspace:GetDescendants()) do
			if part:IsA("BasePart") and not part.Parent:FindFirstChild("Humanoid") then
				if originalReflectance[part] == nil then originalReflectance[part] = part.Reflectance end
				part.Reflectance = 0.15 
			end
		end
	else
		for part, oldRef in pairs(originalReflectance) do
			if part and part.Parent then part.Reflectance = oldRef end
		end
		originalReflectance = {}
	end
end)

