-- UI Dragging functionality
local dragging, dragInput, dragStart, startPos
MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragging = false end
        end)
    end
end)
MainFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- Toggle Logic
ToggleBtn.MouseButton1Click:Connect(function()
    CustomFarmSettings.Active = not CustomFarmSettings.Active
    updateVisualizer()
    if CustomFarmSettings.Active then
        ToggleBtn.Text = "Farm: ON"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(50, 180, 100)
    else
        ToggleBtn.Text = "Farm: OFF"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(180, 50, 50)
    end
end)

-- Slider Logic (Min: 1, Max: 5000)
local minVal = 1
local maxVal = 5000

local function updateSlider(input)
    local relativeX = math.clamp((input.Position.X - SliderBackground.AbsolutePosition.X) / SliderBackground.AbsoluteSize.X, 0, 1)
    SliderFill.Size = UDim2.new(relativeX, 0, 1, 0)
    SliderBtn.Position = UDim2.new(relativeX, -6, 0, -3)
    
    local calculatedValue = math.floor(minVal + (relativeX * (maxVal - minVal)))
    if calculatedValue < 1 then calculatedValue = 1 end
    
    CustomFarmSettings.Range = calculatedValue
    SliderValueLabel.Text = "Range: " .. tostring(calculatedValue) .. " studs"
    updateVisualizer()
end

local sliderActive = false
SliderBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        sliderActive = true
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if sliderActive and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        updateSlider(input)
    end
end)
UserInputService.InputBegan:Connect(function(input)
    if sliderActive and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
        updateSlider(input)
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        sliderActive = false
    end
end)

-- Background farm loop running exactly every 0.75 seconds across all player islands
task.spawn(function()
    while true do
        task.wait(0.75)
        if CustomFarmSettings.Active then
            local char = plr.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            
            if hrp then
                -- Keep ring matched to character tracking position changes
                if visualRing.Parent ~= hrp then 
                    updateVisualizer() 
                end
                
                -- Loop through ALL plots on the server exactly like the big menu
                for _, plot in ipairs(plotsFolder:GetChildren()) do
                    local resources = plot:FindFirstChild("Resources")
                    if resources then
                        for _, r in ipairs(resources:GetChildren()) do
                            local targetPart = r:IsA("Model") and r.PrimaryPart or r:FindFirstChildWhichIsA("BasePart")
                            if targetPart then
                                local distance = (hrp.Position - targetPart.Position).Magnitude
                                if distance <= CustomFarmSettings.Range then
                                    game:GetService("ReplicatedStorage"):WaitForChild("Communication"):WaitForChild("HitResource"):FireServer(r)
                                end
                            end
                        end
                    end
                end
            end
        end
    end
end)
