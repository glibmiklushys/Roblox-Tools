--// Radius Visualizer Setup
local visualRing = Instance.new("CylinderHandleAdornment")
visualRing.Name = "FarmRadiusVisualizer"
visualRing.Color3 = Color3.fromRGB(255, 0, 0)
visualRing.Transparency = 0.4
visualRing.AlwaysOnTop = false
visualRing.ZIndex = 5

local function updateVisualizer()
    local char = plr.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    
    if hrp and CustomFarmSettings.Active then
        visualRing.Adornee = hrp
        visualRing.Height = 0.2 
        visualRing.Radius = CustomFarmSettings.Range
        visualRing.CFrame = CFrame.new(0, -3, 0) * CFrame.Angles(math.rad(90), 0, 0)
        visualRing.Parent = hrp
    else
        visualRing.Parent = nil
    end
end

plr.CharacterAdded:Connect(function()
    task.wait(1)
    updateVisualizer()
end)

