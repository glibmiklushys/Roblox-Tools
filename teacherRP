local function updateToggleVisual(btn, state, name)
    btn.Text = "  " .. name .. ": " .. (state and "ON" or "OFF")
    btn.BackgroundColor3 = state and Color3.fromRGB(50, 150, 50) or Color3.fromRGB(60, 60, 65)
end

local function refreshVisuals()
    for _, inst in pairs(espInstances) do inst:Destroy() end
    for _, inst in pairs(nametagInstances) do inst:Destroy() end
    table.clear(espInstances)
    table.clear(nametagInstances)

    if not isESPOn and not isNametagsOn then return end

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            if isESPOn then
                local hl = Instance.new("Highlight")
                hl.Adornee = p.Character
                hl.FillColor = currentESPColor
                hl.FillTransparency = 0.5
                hl.OutlineColor = currentESPColor
                hl.OutlineTransparency = 0
                hl.Parent = CoreGui
                table.insert(espInstances, hl)
            end
            if isNametagsOn and p.Character:FindFirstChild("Head") then
                local bg = Instance.new("BillboardGui")
                bg.Adornee = p.Character.Head
                bg.Size = UDim2.new(0, 100, 0, 40)
                bg.StudsOffset = Vector3.new(0, 3, 0)
                bg.AlwaysOnTop = true
                
                local label = Instance.new("TextLabel", bg)
                label.Size = UDim2.new(1, 0, 1, 0)
                label.BackgroundTransparency = 1
                label.Text = p.Name
                label.TextColor3 = currentESPColor
                label.TextStrokeTransparency = 0
                label.Font = Enum.Font.GothamBold
                label.TextSize = 14
                
                bg.Parent = CoreGui
                table.insert(nametagInstances, bg)
            end
        end
    end
end

