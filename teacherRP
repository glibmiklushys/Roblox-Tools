local function refreshPlayerTabs()
    for _, child in pairs(playerListFrame:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end
    
    local plist = Players:GetPlayers()
    table.sort(plist, function(a, b)
        local aFav = favoritePlayers[a.Name] and 1 or 0
        local bFav = favoritePlayers[b.Name] and 1 or 0
        if aFav ~= bFav then return aFav > bFav end
        return a.Name:lower() < b.Name:lower()
    end)
    
    for _, target in pairs(plist) do
        if target ~= player then
            local row = Instance.new("Frame", playerListFrame)
            row.Size = UDim2.new(1, 0, 0, 40)
            row.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
            local cornerRow = Instance.new("UICorner", row)
            cornerRow.CornerRadius = UDim.new(0, 6)
            
            local nameLabel = Instance.new("TextLabel", row)
            nameLabel.Size = UDim2.new(0.5, -10, 1, 0)
            nameLabel.Position = UDim2.new(0, 10, 0, 0)
            nameLabel.BackgroundTransparency = 1
            nameLabel.Text = (favoritePlayers[target.Name] and "⭐ " or "") .. target.Name
            nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
            nameLabel.Font = Enum.Font.GothamSemibold
            nameLabel.TextSize = 14
            nameLabel.TextXAlignment = Enum.TextXAlignment.Left
            
            local tpBtn = Instance.new("TextButton", row)
            tpBtn.Size = UDim2.new(0.25, -5, 0, 30)
            tpBtn.Position = UDim2.new(0.5, 0, 0.5, -15)
            tpBtn.BackgroundColor3 = Color3.fromRGB(70, 130, 180)
            tpBtn.Text = "TP Behind"
            tpBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
            tpBtn.Font = Enum.Font.GothamBold
            tpBtn.TextSize = 12
            local cornerTp = Instance.new("UICorner", tpBtn)
            cornerTp.CornerRadius = UDim.new(0, 4)
            
            tpBtn.MouseButton1Click:Connect(function()
                if player.Character and player.Character:FindFirstChild("HumanoidRootPart") and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                    player.Character.HumanoidRootPart.CFrame = target.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3)
                end
            end)
            
            local favBtn = Instance.new("TextButton", row)
            favBtn.Size = UDim2.new(0.25, -10, 0, 30)
            favBtn.Position = UDim2.new(0.75, 5, 0.5, -15)
            favBtn.BackgroundColor3 = favoritePlayers[target.Name] and Color3.fromRGB(200, 150, 50) or Color3.fromRGB(55, 55, 60)
            favBtn.Text = favoritePlayers[target.Name] and "Unfav" or "Fav"
            favBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
            favBtn.Font = Enum.Font.GothamBold
            favBtn.TextSize = 12
            local cornerFav = Instance.new("UICorner", favBtn)
            cornerFav.CornerRadius = UDim.new(0, 4)
            
            favBtn.MouseButton1Click:Connect(function()
                favoritePlayers[target.Name] = not favoritePlayers[target.Name]
                refreshPlayerTabs()
            end)
        end
    end
end

