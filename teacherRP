-- Noclip Logic (Stepped runs before physics calculate)
table.insert(connections, RunService.Stepped:Connect(function()
    if isNoclipOn and player.Character then
        for _, part in pairs(player.Character:GetDescendants()) do
            if part:IsA("BasePart") and part.CanCollide then
                part.CanCollide = false
            end
        end
    end
end))

-- RenderStepped Logic (Movement, Patrol, Speed)
table.insert(connections, RunService.RenderStepped:Connect(function()
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChild("Humanoid")
    if not hrp or not hum then return end

    if isSpeedOn then
        hum.WalkSpeed = tonumber(speedInput.Text) or 50
    end

    if isFlyOn then
        workspace.Gravity = 0
        local spd = tonumber(flyInput.Text) or 50
        
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then flyCtrl.f = spd else flyCtrl.f = 0 end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then flyCtrl.b = -spd else flyCtrl.b = 0 end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then flyCtrl.l = -spd else flyCtrl.l = 0 end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then flyCtrl.r = spd else flyCtrl.r = 0 end
        
        lastCtrl = {f = flyCtrl.f, b = flyCtrl.b, l = flyCtrl.l, r = flyCtrl.r}
        
        local moveDir = Vector3.new(lastCtrl.l + lastCtrl.r, 0, lastCtrl.f + lastCtrl.b)
        if moveDir.Magnitude > 0 then
            hrp.CFrame = hrp.CFrame * CFrame.new(lastCtrl.l + lastCtrl.r, 0, -(lastCtrl.f + lastCtrl.b))
        end
        hrp.CFrame = CFrame.new(hrp.Position, hrp.Position + camera.CFrame.LookVector)
        hum.PlatformStand = true
    else
        hum.PlatformStand = false
    end

    -- UPDATED PATROL WALKING LOGIC
    if isPatrolOn and #patrolPoints > 0 and not isFlyOn then
        local targetPos = patrolPoints[patrolIndex].Position
        
        -- Make the humanoid walk to the current point
        hum:MoveTo(targetPos)
        
        -- Check distance (ignoring Y axis to prevent getting stuck on slight bumps)
        local flatHrpPos = Vector3.new(hrp.Position.X, 0, hrp.Position.Z)
        local flatTargetPos = Vector3.new(targetPos.X, 0, targetPos.Z)
        
        -- If player is within 4 studs of the point, cycle to the next one
        if (flatHrpPos - flatTargetPos).Magnitude < 4 then
            patrolIndex = patrolIndex + 1
            if patrolIndex > #patrolPoints then
                patrolIndex = 1
            end
        end
    end
end))

