local animStyle = TweenInfo.new(0.18, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)

-- Helper to inject ultra-smooth hover & click tweens into any button instantly
local function applyModernInteractiveTweens(btn, normalColor)
    btn.BackgroundColor3 = normalColor
    btn:SetAttribute("CurrentBaseColor", normalColor)
    btn.AutoButtonColor = false
    
    local stroke = Instance.new("UIStroke", btn)
    stroke.Color = PALETTE.AccentCyan
    stroke.Transparency = 1 
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

    btn.MouseEnter:Connect(function()
        local base = btn:GetAttribute("CurrentBaseColor")
        local hovered = base:Lerp(Color3.new(1,1,1), 0.12)
        TweenService:Create(btn, animStyle, {BackgroundColor3 = hovered}):Play()
        TweenService:Create(stroke, animStyle, {Transparency = 0.35}):Play()
    end)

    btn.MouseLeave:Connect(function()
        local base = btn:GetAttribute("CurrentBaseColor")
        TweenService:Create(btn, animStyle, {BackgroundColor3 = base}):Play()
        TweenService:Create(stroke, animStyle, {Transparency = 1}):Play()
    end)

    btn.MouseButton1Down:Connect(function()
        local base = btn:GetAttribute("CurrentBaseColor")
        local pressed = base:Lerp(Color3.new(0,0,0), 0.2)
        TweenService:Create(btn, TweenInfo.new(0.04), {BackgroundColor3 = pressed}):Play()
        TweenService:Create(stroke, TweenInfo.new(0.04), {Transparency = 0}):Play()
    end)

    btn.MouseButton1Up:Connect(function()
        local base = btn:GetAttribute("CurrentBaseColor")
        local hovered = base:Lerp(Color3.new(1,1,1), 0.12)
        TweenService:Create(btn, animStyle, {BackgroundColor3 = hovered}):Play()
        TweenService:Create(stroke, animStyle, {Transparency = 0.35}):Play()
    end)
end

-- Helper to morph toggle states smoothly
local function morphToggleVisuals(btn, isOn, textPrefix)
    local targetColor = isOn and PALETTE.ToggleOn or PALETTE.ToggleOff
    btn:SetAttribute("CurrentBaseColor", targetColor)
    btn.Text = textPrefix .. (isOn and ": ON" or ": OFF")
    TweenService:Create(btn, animStyle, {BackgroundColor3 = targetColor}):Play()
end

