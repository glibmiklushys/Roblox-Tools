-- Inv Trigger Toggle
invTriggerBtn.MouseButton1Click:Connect(function()
    isInvTriggering = not isInvTriggering
    morphToggleVisuals(invTriggerBtn, isInvTriggering, "Inv Trigger")
    
    if isInvTriggering then
        invTriggerLoop = task.spawn(function()
            while isInvTriggering do
                local playerGui = player:FindFirstChild("PlayerGui")
                if playerGui then
                    local shelfPicker = playerGui:FindFirstChild("ShelfItemPicker")
                    
                    if not shelfPicker then
                        for _, gui in pairs(playerGui:GetChildren()) do
                            if gui:FindFirstChild("AddBtn") and getconnections then
                                for _, connection in pairs(getconnections(gui.AddBtn.MouseButton1Click)) do
                                    connection:Fire()
                                end
                                break
                            end
                        end
                        task.wait(0.4) 
                        shelfPicker = playerGui:FindFirstChild("ShelfItemPicker")
                    end
                    
                    if shelfPicker then
                        local panel = shelfPicker:FindFirstChild("ShelfPickerPanel")
                        local content = panel and panel:FindFirstChild("Content")
                        
                        if content then
                            for _, item in pairs(content:GetChildren()) do
                                if not isInvTriggering then break end
                                
                                if (item:IsA("TextButton") or item:IsA("GuiButton")) and string.match(item.Name, "^Item_") and getconnections then 
                                    for _, connection in pairs(getconnections(item.MouseButton1Click)) do
                                        connection:Fire()
                                    end
                                    task.wait(0.05)
                                    
                                    local confirmPrompt = panel:FindFirstChild("ConfirmPrompt")
                                    if confirmPrompt and confirmPrompt.Visible ~= false then
                                        local confirmBtn = confirmPrompt:FindFirstChild("ConfirmButton", true)
                                        if confirmBtn and getconnections then
                                            for _, cConn in pairs(getconnections(confirmBtn.MouseButton1Click)) do
                                                cConn:Fire()
                                            end
                                            task.wait(0.05) 
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
                task.wait(0.5) 
            end
        end)
    else
        if invTriggerLoop then task.cancel(invTriggerLoop) end
    end
end)

