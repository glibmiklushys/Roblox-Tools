    if not player.Character then return end

    local myPlot = getMyPlot()
    local zone = (myPlot and myPlot:FindFirstChild("UnpackZone", true)) or workspace:FindFirstChild("UnpackZone", true)
    local targetCFrame = nil

    if zone then
        targetCFrame = zone:GetPivot() + Vector3.new(0, 5, 0)
        lastKnownUnloadCFrame = targetCFrame
    elseif lastKnownUnloadCFrame then
        targetCFrame = lastKnownUnloadCFrame
