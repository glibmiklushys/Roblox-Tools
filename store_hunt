local isTracking, renderConnection, debounce = false, nil, false
toggleButton.MouseButton1Click:Connect(function()
    isTracking = not isTracking
    morphToggleVisuals(toggleButton, isTracking, "Auto-Bid")
    
    if isTracking then
        renderConnection = RunService.RenderStepped:Connect(function()
            pcall(function()
                -- Dynamically find the event inside the loop to prevent script hanging on inject
                local bidEvent = ReplicatedStorage:FindFirstChild("Events")
                if bidEvent then bidEvent = bidEvent:FindFirstChild("Auction") end
                if bidEvent then bidEvent = bidEvent:FindFirstChild("Bid") end
                
                local track = player.PlayerGui.UIControllerGui.AuctionBiddingContainer.BidBarRow.Track
                if bidEvent and (track.Cursor.AbsolutePosition - track.BidZone.AbsolutePosition).Magnitude <= 5 and not debounce then
                    debounce = true
                    bidEvent:FireServer()
                    task.delay(0.5, function() debounce = false end)
                end
            end)
        end)
    else
        if renderConnection then renderConnection:Disconnect() end
    end
end)

-- TP Unload (Now featuring automated memory fallback caching)
