local function getMyPlot()
    local plots = workspace:FindFirstChild("_Plots")
    if not plots then return nil end
    for i = 1, 12 do
        local p = plots:FindFirstChild("Plot" .. i)
        if p and p:FindFirstChild("Furniture") then
            local sign = p.Furniture:FindFirstChild("Shop Sign 4")
            if sign then
                for _, child in ipairs(sign:GetChildren()) do
                    local gui = child:FindFirstChild("Part") and child.Part:FindFirstChild("SurfaceGui")
                    if gui and gui:FindFirstChild("TextLabel") and string.find(string.lower(gui.TextLabel.Text), string.lower(player.DisplayName)) then
                        return p
                    end
                end
            end
        end
    end
    return nil
end

local function UpdateNum()
    Num.Text = tostring(number)
end

local function setupCharacterSpeed(character)
    if not character then return end
    local humanoid = character:WaitForChild("Humanoid", 10)
    if not humanoid then return end

    isUpdatingSpeed = true
    humanoid.WalkSpeed = number
    isUpdatingSpeed = false
    UpdateNum()

    if speedConnection then speedConnection:Disconnect() end
    speedConnection = humanoid:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
        if isUpdatingSpeed then return end
        
        if humanoid.WalkSpeed ~= number then
            isUpdatingSpeed = true
            humanoid.WalkSpeed = number 
            isUpdatingSpeed = false
            UpdateNum()
        end
    end)
end


