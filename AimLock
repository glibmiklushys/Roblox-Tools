-- Optimized for direct execution / run command (Right Click Hold)
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")

local LocalPlayer = Players.LocalPlayer
local Camera = Workspace.CurrentCamera

-- Configuration
local LOCK_INPUT = Enum.UserInputType.MouseButton2 -- Right Mouse Button
local SMOOTHNESS = 1.0                             -- 1 = Instant snapping (no interpolation lag)
local FOV_LIMIT = 90                               -- Visual Field of View boundary in degrees

-- Cleanup script if it was run previously (prevents camera lagging/stacking)
if _G.AimLockConnection then
	_G.AimLockConnection:Disconnect()
	_G.AimLockConnection = nil
end

-- Math calculation to check if a player is within a 90 FOV boundary and find the closest to crosshair
local function getClosestPlayerToCrosshair()
	local closestPlayer = nil
	local shortestDistance = math.huge
	
	local viewportSize = Camera.ViewportSize
	local screenCenter = Vector2.new(viewportSize.X / 2, viewportSize.Y / 2)
	
	-- Calculate the pixel radius that represents a 90 FOV cone based on your current screen height
	-- Formula uses the tangent of the half-angles to accurately map degrees to screen pixels
	local fovRadius = (viewportSize.Y / 2) * (math.tan(math.rad(FOV_LIMIT / 2)) / math.tan(math.rad(Camera.FieldOfView / 2)))

	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("Head") then
			local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
			if humanoid and humanoid.Health > 0 then
				local head = player.Character.Head
				
				-- Translate 3D position to 2D screen space
				local screenPos, onScreen = Camera:WorldToViewportPoint(head.Position)
				
				if onScreen then
					-- Calculate how many pixels away they are from the crosshair
					local crosshairDistance = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
					
					-- Only target if they are within your specified 90 FOV boundary radius
					if crosshairDistance <= fovRadius then
						if crosshairDistance < shortestDistance then
							shortestDistance = crosshairDistance
							closestPlayer = player
						end
					end
				end
			end
		end
	end
	return closestPlayer
end

-- Frame-by-frame loop
_G.AimLockConnection = RunService.RenderStepped:Connect(function()
	-- Checks if Right Mouse Button is being held, and ensures you aren't typing in chat/menus
	if UserInputService:IsMouseButtonPressed(LOCK_INPUT) and not UserInputService:GetFocusedTextBox() then
		local targetPlayer = getClosestPlayerToCrosshair()
		
		if targetPlayer and targetPlayer.Character and targetPlayer.Character:FindFirstChild("Head") then
			local targetHead = targetPlayer.Character.Head
			local targetCFrame = CFrame.lookAt(Camera.CFrame.Position, targetHead.Position)
			
			-- Instant snap (SMOOTHNESS = 1 skips interpolation lag entirely)
			Camera.CFrame = Camera.CFrame:Lerp(targetCFrame, SMOOTHNESS)
		end
	end
end)

print("Aim lock successfully executed. Instant snap [1.0 smoothness] with a strict [90 FOV] boundary initialized.")
